# Server port
PORT=4000

# Frontend origin used by CORS during local development
CLIENT_ORIGIN=http://localhost:4000

# SQLite database path.
# Local development default: stores the database in server/data/dev.db.
# Production recommended: use an absolute path, for example file:/opt/wangchu/server/data/dev.db on Linux.
DATABASE_URL=file:../data/dev.db

# Change this to a long random string before real deployment
JWT_SECRET=replace-with-a-long-random-secret

# Admin login cookie name
COOKIE_NAME=admin_session

# Initial admin account created by npm run db:seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
